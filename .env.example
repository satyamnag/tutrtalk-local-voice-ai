# Local-only LiveKit dev defaults — override LIVEKIT_URL to point at LiveKit Cloud.
LIVEKIT_URL=placeholder
LIVEKIT_API_KEY=placeholder
LIVEKIT_API_SECRET=placeholder
LIVEKIT_NODE_IP=placeholder
MANAGE_LIVEKIT=placeholder


# LLM (llama.cpp server is a managed subprocess by default)
LLAMA_BASE_URL=placeholder
LLAMA_MODEL=placeholder
LLAMA_API_KEY=placeholder
LLAMA_MODEL_ALIAS=placeholder
LLAMA_HF_REPO=placeholder
LLAMA_CTX_SIZE=placeholder
LLAMA_N_GPU_LAYERS=placeholder
MANAGE_LLAMA=placeholder

# STT (Nemotron is the default; set STT_PROVIDER=placeholder
STT_PROVIDER=placeholder
STT_BASE_URL=placeholder
STT_MODEL=placeholder
STT_API_KEY=placeholder
NEMOTRON_MODEL_NAME=placeholder
NEMOTRON_MODEL_ID=placeholder

# TTS (Kokoro)
TTS_BASE_URL=placeholder
TTS_VOICE=placeholder

# Web (FastAPI: token route + static frontend)
WEB_PORT=placeholder

# Optional Whisper fallback
VOXBOX_HF_REPO_ID=placeholder
