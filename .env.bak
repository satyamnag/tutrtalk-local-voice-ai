# Local-only LiveKit dev defaults — override LIVEKIT_URL to point at LiveKit Cloud.
LIVEKIT_URL=wss://curly-cod-r44xvpvj544whx694-7880.app.github.dev
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_NODE_IP=curly-cod-r44xvpvj544whx694.app.github.dev
MANAGE_LIVEKIT=1


# LLM (llama.cpp server is a managed subprocess by default)
LLAMA_BASE_URL=https://api.openai.com/v1
LLAMA_MODEL=gpt-4o-mini
LLAMA_API_KEY=placeholder
LLAMA_MODEL_ALIAS=qwen3-4b
LLAMA_HF_REPO=unsloth/Qwen3-4B-Instruct-2507-GGUF
LLAMA_CTX_SIZE=16384
LLAMA_N_GPU_LAYERS=0
MANAGE_LLAMA=false

# STT (Nemotron is the default; set STT_PROVIDER=whisper for the vox-box fallback)
STT_PROVIDER=whisper
STT_BASE_URL=http://127.0.0.1:8000/v1
STT_MODEL=nemotron-speech-streaming
STT_API_KEY=no-key-needed
NEMOTRON_MODEL_NAME=nvidia/nemotron-speech-streaming-en-0.6b
NEMOTRON_MODEL_ID=nemotron-speech-streaming

# TTS (Kokoro)
TTS_BASE_URL=http://127.0.0.1:8880/v1
TTS_VOICE=af_nova

# Web (FastAPI: token route + static frontend)
WEB_PORT=8080

# Optional Whisper fallback
VOXBOX_HF_REPO_ID=Systran/faster-whisper-small
